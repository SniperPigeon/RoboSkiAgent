# ══════════════════════════════════════════════════════════════════════════════
# RoboSkiAgent Environment Configuration
# Copy this file to .env and fill in real values. Never commit .env to git.
# ══════════════════════════════════════════════════════════════════════════════

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Which backend to use: "claude" | "llamacpp" (default) | "ollama"
ROBOSKI_LLM_PROVIDER="llamacpp"

# ── Claude / Anthropic ────────────────────────────────────────────────────────
# Only needed when ROBOSKI_LLM_PROVIDER=claude
ANTHROPIC_API_KEY="your_anthropic_api_key_here"
# ANTHROPIC_MODEL="claude-sonnet-4-6"

# ── llama.cpp (local LLM, recommended) ────────────────────────────────────────
# Only needed when ROBOSKI_LLM_PROVIDER=llamacpp
#
# LLAMACPP_BASE_URL:   OpenAI-compatible endpoint exposed by llama-server
# LLAMACPP_MODEL_REPO: HuggingFace repo to download from (auto-download on first run)
# LLAMACPP_MODEL_FILE: GGUF filename inside that repo
# LLAMACPP_MODEL_DIR:  Local directory to store the downloaded GGUF file
#
LLAMACPP_BASE_URL="http://localhost:8080/v1"
LLAMACPP_MODEL_REPO="bartowski/Qwen_Qwen3-8B-GGUF"
LLAMACPP_MODEL_FILE="Qwen_Qwen3-8B-Q4_K_M.gguf"
LLAMACPP_MODEL_DIR="./models"
#
# Start the server after first download (adjust -ngl to your VRAM):
#   llama-server -m ./models/Qwen_Qwen3-8B-Q4_K_M.gguf \
#                --host 0.0.0.0 --port 8080 -ngl 99 -c 8192
#
# China mirror (optional):
#   HF_ENDPOINT="https://hf-mirror.com"

# ── Ollama (local LLM, alternative) ───────────────────────────────────────────
# Only needed when ROBOSKI_LLM_PROVIDER=ollama
# OLLAMA_MODEL_ID="qwen3:latest"
# OLLAMA_BASE_URL="http://localhost:11434"

# ── LangSmith Tracing (Optional) ──────────────────────────────────────────────
# Set LANGSMITH_TRACING=true to enable; auto-enabled when API key is present.
LANGSMITH_TRACING="true"
LANGSMITH_API_KEY="your_langsmith_api_key_here"
LANGSMITH_PROJECT="robo-ski-agent"
LANGSMITH_ENDPOINT="https://api.smith.langchain.com"

# ── Hugging Face ──────────────────────────────────────────────────────────────
# HUGGINGFACEHUB_API_TOKEN=your_hf_token_here

# ── Simulation / Debug ────────────────────────────────────────────────────────
# Skip IK/collision checks (simulation mode). true = skip, false = full checks.
# GUI defaults to true; CLI defaults to false unless --skip-check flag is passed.
ROBOSKI_SKIP_CHECK="true"

# ── RoboDK ───────────────────────────────────────────────────────────────────
# RoboDK installation path (if needed for advanced features)
# ROBODK_PATH="C:\RoboDK\bin\RoboDK.exe"
