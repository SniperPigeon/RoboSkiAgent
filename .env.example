# ══════════════════════════════════════════════════════════════════════════════
# RoboSkiAgent Environment Configuration
# ══════════════════════════════════════════════════════════════════════════════

# ── LLM API Keys ──────────────────────────────────────────────────────────────
# Claude (Anthropic)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI (if needed)
# OPENAI_API_KEY=your_openai_api_key_here

# Hugging Face (for local models)
# HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# ── LangSmith Tracing (Optional) ──────────────────────────────────────────────
# Set to "true" to enable LangSmith tracing for debugging
LANGSMITH_TRACING=false

# if true, decomment the following two lines.
# LANGSMITH_API_KEY=your_langsmith_api_key_here
# LANGSMITH_PROJECT=robo-ski-agent

# ── LangGraph Studio ─────────────────────────────────────────────────────────
# No additional config needed — langgraph.json handles graph discovery

# ── RoboDK ───────────────────────────────────────────────────────────────────
# RoboDK installation path (if needed for advanced features)
# ROBODK_PATH=C:\RoboDK\bin\RoboDK.exe

# ── Application Settings ──────────────────────────────────────────────────────
# Debug mode
DEBUG=false
