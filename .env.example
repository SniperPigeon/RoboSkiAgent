# ══════════════════════════════════════════════════════════════════════════════
# RoboSkiAgent Environment Configuration
# Copy this file to .env and fill in real values. Never commit .env to git.
# ══════════════════════════════════════════════════════════════════════════════

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Which backend to use: "claude" (default) or "ollama"
ROBOSKI_LLM_PROVIDER="ollama"

# ── Claude / Anthropic ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY="your_anthropic_api_key_here"
# Model version (default: claude-sonnet-4-6)
ANTHROPIC_MODEL="claude-sonnet-4-6"

# ── Ollama (local LLM) ────────────────────────────────────────────────────────
# Only needed when ROBOSKI_LLM_PROVIDER=ollama
# OLLAMA_MODEL_ID="qwen3:latest"
# OLLAMA_BASE_URL="http://localhost:11434"

# ── LangSmith Tracing (Optional) ──────────────────────────────────────────────
# Set LANGSMITH_TRACING=true to enable; auto-enabled when API key is present.
LANGSMITH_TRACING="true"
LANGSMITH_API_KEY="your_langsmith_api_key_here"
LANGSMITH_PROJECT="robo-ski-agent"
LANGSMITH_ENDPOINT="https://api.smith.langchain.com"

# ── Hugging Face ──────────────────────────────────────────────────────────────
# HUGGINGFACEHUB_API_TOKEN=your_hf_token_here

# ── Simulation / Debug ────────────────────────────────────────────────────────
# Skip IK/collision checks (simulation mode). true = skip, false = full checks.
# GUI defaults to true; CLI defaults to false unless --skip-check flag is passed.
ROBOSKI_SKIP_CHECK="true"

# ── RoboDK ───────────────────────────────────────────────────────────────────
# RoboDK installation path (if needed for advanced features)
# ROBODK_PATH="C:\RoboDK\bin\RoboDK.exe"
